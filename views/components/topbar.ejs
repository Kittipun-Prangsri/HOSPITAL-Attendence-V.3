<%
  let pageTitle = "Dashboard";
  const currentRoute = typeof activeRoute !== 'undefined' ? activeRoute : '/';
  
  if (currentRoute === '/') {
    pageTitle = "Dashboard";
  } else if (currentRoute === '/schedule') {
    pageTitle = "ตารางเวรตัวเอง";
  } else if (currentRoute === '/excuses') {
    pageTitle = "แจ้งสาเหตุ / ขาด ลา สาย";
  } else if (currentRoute === '/attendance') {
    pageTitle = "บันทึกเข้า-ออกงาน";
  } else if (currentRoute === '/personnel') {
    pageTitle = "ข้อมูลบุคลากร";
  } else if (currentRoute === '/scheduling') {
    pageTitle = "จัดตารางเวรพยาบาล";
  } else if (currentRoute === '/reports') {
    pageTitle = "แดชบอร์ดวิเคราะห์";
  } else if (currentRoute === '/report/daily') {
    pageTitle = "รายงานสรุปรายวัน";
  } else if (currentRoute === '/report/monthly') {
    pageTitle = "รายงานสรุปรายเดือน";
  } else if (currentRoute === '/report/hours') {
    pageTitle = "สรุปชั่วโมงทำงาน";
  } else if (currentRoute === '/admin/users') {
    pageTitle = "จัดการผู้เข้าใช้";
  } else if (currentRoute === '/admin/permissions') {
    pageTitle = "ตั้งค่าระดับสิทธิ์";
  } else if (currentRoute.startsWith('/department/')) {
    pageTitle = "กลุ่มงาน" + (typeof deptName !== 'undefined' && deptName ? deptName : '');
  }
%>

<!-- TOPBAR -->
<div class="topbar">
  <div class="d-flex align-items-center gap-3">
    <button class="icon-btn me-2 topbar-toggle-btn" onclick="toggleGlobalSidebar()">
      <i class="bi bi-list"></i>
    </button>

    <script>
      function toggleGlobalSidebar() {
        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('.main');
        const overlay = document.getElementById('sidebar-overlay');
        
        if (window.innerWidth < 992) {
          sidebar.classList.toggle('mobile-active');
          if (overlay) overlay.classList.toggle('active');
        } else {
          if (sidebar) sidebar.classList.toggle('collapsed');
          if (main) main.classList.toggle('expanded');
        }
      }
    </script>
    <div class="topbar-left">
      <h6 style="font-weight: 700; color: var(--primary, #0D9488); margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 180px;"><%= pageTitle %><span class="d-none d-md-inline"> - KHH (<%= locals.user ? user.role.toUpperCase() : 'USER' %>)</span></h6>
      <small id="currentDate" class="text-muted" style="white-space: nowrap;">กำลังโหลด...</small>
    </div>
  </div>

  <style>
    .topbar-toggle-btn {
      display: none !important;
    }
    @media (max-width: 991px) {
      .topbar-toggle-btn {
        display: flex !important;
      }
    }
  </style>
  <div class="d-flex align-items:center gap-2" style="display:flex;align-items:center;gap:8px;">
    <div class="live-pill" style="white-space: nowrap;"><span class="live-dot"></span> <span class="d-none d-sm-inline">ระบบออนไลน์</span></div>
    <div class="icon-btn" title="แจ้งเตือน"><i class="bi bi-bell"></i></div>
    <div class="icon-btn" title="รีเฟรช" onclick="refreshData(this)"><i class="bi bi-arrow-clockwise"></i></div>
    <div class="icon-btn" title="ตั้งค่า" onclick="openSettings()"><i class="bi bi-gear"></i></div>
  </div>
</div>

<script>
  // Live ticking clock for topbar
  function initTopbarClock() {
    const dateEl = document.getElementById('currentDate');
    if (!dateEl) return;

    window.updateTopbarClock = function() {
      const now = new Date();
      
      // Check if we are on dashboard and a different date is selected
      const dateInput = document.getElementById('dateInput');
      if (dateInput && dateInput.value) {
        const y = now.getFullYear();
        const m = String(now.getMonth() + 1).padStart(2, '0');
        const d = String(now.getDate()).padStart(2, '0');
        const todayStr = `${y}-${m}-${d}`;
        
        if (dateInput.value !== todayStr) {
          const selectedDate = new Date(dateInput.value);
          if (window.innerWidth < 768) {
            dateEl.textContent = "วันที่: " + selectedDate.toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: '2-digit' });
          } else {
            dateEl.textContent = "ข้อมูลของวันที่: " + selectedDate.toLocaleDateString('th-TH', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
          }
          return;
        }
      }

      if (window.innerWidth < 768) {
        const datePart = now.toLocaleDateString('th-TH', { day: 'numeric', month: 'short' });
        const timePart = now.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' });
        dateEl.textContent = `${datePart} | ${timePart} น.`;
      } else {
        const datePart = now.toLocaleDateString('th-TH', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        const timePart = now.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        dateEl.textContent = `${datePart} เวลา ${timePart} น.`;
      }
    };

    window.updateTopbarClock();
    setInterval(window.updateTopbarClock, 1000);
  }
  initTopbarClock();

  // Dashboard Initialization: Store User Role from Session to localStorage
  const sessionRole = "<%= (locals.user && user.role) ? user.role : 'staff' %>";
  localStorage.setItem('userRole', sessionRole);
  const CURRENT_ROLE = localStorage.getItem('userRole');
  const CURRENT_USER_ID = "<%= (locals.user && user.username) ? user.username : '' %>";
  
  const RBAC_ENABLED = true; // เปิดระบบ RBAC แล้ว
  console.log('Current User Role:', CURRENT_ROLE, '| User ID:', CURRENT_USER_ID, '| RBAC_ENABLED:', RBAC_ENABLED);

  // Load appPermissions from localStorage
  const appPermissions = JSON.parse(localStorage.getItem('APP_PERMISSIONS')) || {
    admin: ['view_dashboard', 'view_phone', 'view_email', 'edit_staff', 'delete_staff', 'manage_permissions'],
    staff: ['view_dashboard'],
    user: ['view_dashboard']
  };

  // Global Check Permission
  function checkPermission(capability) {
    if (!RBAC_ENABLED) return true;
    if (CURRENT_ROLE === 'admin' || CURRENT_ROLE === 'super') return true;
    return appPermissions[CURRENT_ROLE] && appPermissions[CURRENT_ROLE].includes(capability);
  }

  // Enforce UI restrictions based on role
  document.addEventListener("DOMContentLoaded", () => {
     if (CURRENT_ROLE === 'admin' || CURRENT_ROLE === 'staff' || CURRENT_ROLE === 'user') {
         // Disable permissions menu and users menu in sidebar (if they exist in the DOM)
         const permissionsMenu = document.querySelector('a[href="/admin/permissions"]');
         if(permissionsMenu) {
             permissionsMenu.style.display = 'none';
         }
         const usersMenu = document.querySelector('a[href="/admin/users"]');
         if(usersMenu) {
             usersMenu.style.display = 'none';
         }
     }

     if (CURRENT_ROLE === 'staff' || CURRENT_ROLE === 'user') {
         // Disable settings menu icon in topbar
         const settingsBtn = document.querySelector('[onclick="openSettings()"]');
         if(settingsBtn) {
             settingsBtn.style.pointerEvents = 'none';
             settingsBtn.style.opacity = '0.5';
         }
     }
  });

  function maskSensitiveData(str, capability, dataOwnerId) {
    if (!RBAC_ENABLED) return str;
    if (!str || str === '-') return '-';
    // Owner of the data sees everything
    if (dataOwnerId && String(dataOwnerId) === String(CURRENT_USER_ID)) return str;
    // Admin sees everything
    if (checkPermission(capability)) return str;
    
    // Masking phone example: 09xxxx
    if (capability === 'view_phone') {
        return str.substring(0, 2) + '*'.repeat(Math.max(0, str.length - 2)); 
    }
    // Masking email: ITx****@hotmail.com
    if (capability === 'view_email') {
        const parts = str.split('@');
        if(parts.length === 2) {
           return parts[0].substring(0, 2) + '***@' + parts[1];
        }
        return '********';
    }
    // Masking Name: นาย xxx
    if (capability === 'view_name') {
        const titles = ['นายแพทย์', 'พญ.', 'นพ.', 'นาย', 'นางสาว', 'นาง'];
        let title = '';
        let bareName = str;
        for (let t of titles) {
            if (str.startsWith(t)) {
                title = t + ' ';
                bareName = str.substring(t.length).trim();
                break;
            }
        }
        return title + 'x'.repeat(bareName.length > 0 ? bareName.length : 3);
    }
    // Masking ID: KHH00023 -> ***
    if (capability === 'view_id') {
        return '***';
    }
    
    return '********';
  }
</script>

<!-- ========================================================
     SETTINGS MODAL
     ======================================================== -->
<div id="settingsModal" style="
  display:none; position:fixed; inset:0; z-index:9999;
  background:rgba(0,0,0,0.45); backdrop-filter:blur(4px);
  align-items:center; justify-content:center;">
  <div style="
    background:var(--card,#fff); border-radius:18px; width:660px; max-width:96vw;
    max-height:90vh; overflow:hidden; box-shadow:0 24px 64px rgba(0,0,0,0.22);
    display:flex; flex-direction:column; animation:slideUp .25s ease;">

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;padding:22px 28px 16px;border-bottom:1px solid var(--border,#E2E8F0);">
      <div style="display:flex;align-items:center;gap:12px;">
        <div style="background:linear-gradient(135deg,#6366F1,#8B5CF6);border-radius:10px;width:40px;height:40px;display:flex;align-items:center;justify-content:center;">
          <i class="bi bi-gear-fill" style="color:#fff;font-size:18px;"></i>
        </div>
        <div>
          <div style="font-size:17px;font-weight:700;color:var(--text,#1E293B);">ตั้งค่าระบบ</div>
          <div style="font-size:12px;color:var(--muted,#94A3B8);">System Settings</div>
        </div>
      </div>
      <button onclick="closeSettings()" style="border:none;background:var(--surface,#F8FAFC);border-radius:8px;width:36px;height:36px;cursor:pointer;font-size:18px;color:var(--muted,#94A3B8);">✕</button>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;padding:14px 28px 0;border-bottom:1px solid var(--border,#E2E8F0);">
      <button class="stab active" id="stab-1" onclick="switchSettingsTab(1)">
        <i class="bi bi-sliders"></i> ตั้งค่าทำงาน
      </button>
      <button class="stab" id="stab-2" onclick="switchSettingsTab(2)">
        <i class="bi bi-clock"></i> ตั้งเวลาทำงานบุคลากร
      </button>
      <button class="stab" id="stab-3" onclick="switchSettingsTab(3)">
        <i class="bi bi-calendar3"></i> ตั้งค่าประเภทเวร
      </button>
    </div>

    <!-- Body (scrollable) -->
    <div style="flex:1;overflow-y:auto;padding:24px 28px;">

      <!-- TAB 1: Work Settings -->
      <div id="spanel-1" class="spanel">
        <div class="sgroup">
          <label class="slabel">เวลาเริ่มงาน (เช้า)</label>
          <input type="time" id="s-work-start" class="sinput" value="08:00">
        </div>
        <div class="sgroup">
          <label class="slabel">เวลาเลิกงาน (เช้า)</label>
          <input type="time" id="s-work-end" class="sinput" value="16:00">
        </div>
        <div class="sgroup">
          <label class="slabel">เกณฑ์มาสาย (นาที หลังเวลาเริ่มงาน)</label>
          <input type="number" id="s-late-min" class="sinput" value="31" min="1" max="120">
        </div>
        <div class="sgroup">
          <label class="slabel">วันทำงาน</label>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:6px;">
            <% const days = ['อา','จ','อ','พ','พฤ','ศ','ส']; %>
            <% const dayIds = ['sun','mon','tue','wed','thu','fri','sat']; %>
            <% for(let d=0;d<7;d++){ %>
            <label style="display:flex;align-items:center;gap:4px;cursor:pointer;">
              <input type="checkbox" id="s-day-<%= dayIds[d] %>" <%= (d>=1&&d<=5)?'checked':'' %>>
              <span style="font-size:13px;"><%= days[d] %></span>
            </label>
            <% } %>
          </div>
        </div>
        <div class="sgroup">
          <label class="slabel">ระบบส่งรายงานอัตโนมัติ</label>
          <select id="s-auto-report" class="sinput">
            <option value="none">ไม่ส่ง</option>
            <option value="daily" selected>รายวัน</option>
            <option value="weekly">รายสัปดาห์</option>
          </select>
        </div>
      </div>

      <!-- TAB 2: Staff Work Hours -->
      <div id="spanel-2" class="spanel" style="display:none;">
        <div style="margin-bottom:14px;font-size:13px;color:var(--muted,#94A3B8);">กำหนดเวลาเริ่ม–สิ้นสุดงานตามประเภทบุคลากร</div>

        <% const staffTypes = [
          { id:'doctor', label:'แพทย์', icon:'bi-person-badge' },
          { id:'nurse', label:'พยาบาล', icon:'bi-heart-pulse' },
          { id:'staff', label:'เจ้าหน้าที่ทั่วไป', icon:'bi-people' },
          { id:'support', label:'บุคลากรสนับสนุน', icon:'bi-tools' }
        ]; %>

        <% staffTypes.forEach(function(st){ %>
        <div style="background:var(--surface,#F8FAFC);border-radius:12px;padding:14px 16px;margin-bottom:10px;border:1px solid var(--border,#E2E8F0);">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
            <i class="bi <%= st.icon %>" style="color:#6366F1;font-size:16px;"></i>
            <span style="font-size:13px;font-weight:600;"><%= st.label %></span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
            <div>
              <label style="font-size:11px;color:var(--muted,#94A3B8);display:block;margin-bottom:4px;">เวลาเริ่ม</label>
              <input type="time" id="s-<%= st.id %>-start" class="sinput" value="08:00">
            </div>
            <div>
              <label style="font-size:11px;color:var(--muted,#94A3B8);display:block;margin-bottom:4px;">เวลาสิ้นสุด</label>
              <input type="time" id="s-<%= st.id %>-end" class="sinput" value="16:00">
            </div>
            <div>
              <label style="font-size:11px;color:var(--muted,#94A3B8);display:block;margin-bottom:4px;">OT เริ่มหลัง (ชม.)</label>
              <input type="number" id="s-<%= st.id %>-ot" class="sinput" value="8" min="1" max="24">
            </div>
          </div>
        </div>
        <% }); %>
      </div>

      <!-- TAB 3: Shift Types -->
      <div id="spanel-3" class="spanel" style="display:none;">
        <div style="margin-bottom:14px;font-size:13px;color:var(--muted,#94A3B8);">กำหนดช่วงเวลาและชื่อของแต่ละเวร</div>

        <div id="shiftList">
          <!-- rendered by JS -->
        </div>

        <button onclick="addShift()" style="
          margin-top:8px; width:100%; padding:10px; border:2px dashed #C4B5FD;
          border-radius:10px; background:none; color:#7C3AED; font-size:13px;
          font-weight:600; cursor:pointer; transition:all .2s;">
          <i class="bi bi-plus-circle"></i> เพิ่มประเภทเวร
        </button>
      </div>

    </div>

    <!-- Footer -->
    <div style="display:flex;justify-content:flex-end;gap:10px;padding:16px 28px;border-top:1px solid var(--border,#E2E8F0);">
      <button onclick="closeSettings()" style="padding:9px 20px;border-radius:9px;border:1px solid var(--border,#E2E8F0);background:none;cursor:pointer;font-size:13px;font-weight:600;color:var(--muted,#94A3B8);">ยกเลิก</button>
      <button onclick="saveSettings()" style="padding:9px 22px;border-radius:9px;border:none;background:linear-gradient(135deg,#6366F1,#8B5CF6);color:#fff;font-size:13px;font-weight:600;cursor:pointer;box-shadow:0 4px 12px rgba(99,102,241,.35);">
        <i class="bi bi-check2-circle"></i> บันทึกการตั้งค่า
      </button>
    </div>
  </div>
</div>

