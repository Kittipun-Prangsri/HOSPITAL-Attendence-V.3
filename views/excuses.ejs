<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>แจ้งสาเหตุการปฏิบัติงาน - KHH Attendance</title>
    <!-- Google Fonts: Sarabun -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&subset=thai&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .excuse-layout { display: grid; grid-template-columns: 1fr; gap: 24px; }
        @media (min-width: 992px) {
            .excuse-layout { grid-template-columns: 360px 1fr; }
        }
        .form-card { background: #fff; border-radius: 16px; border: 1px solid var(--border); padding: 24px; box-shadow: 0 4px 12px rgba(11, 48, 96, 0.03); }
        .list-card { background: #fff; border-radius: 16px; border: 1px solid var(--border); padding: 24px; box-shadow: 0 4px 12px rgba(11, 48, 96, 0.03); }
        
        /* Badges */
        .status-badge { padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; text-transform: uppercase; }
        .status-pending { background: #fef3c7; color: #d97706; }
        .status-approved { background: #dcfce7; color: #15803d; }
        .status-rejected { background: #fee2e2; color: #b91c1c; }
        
        .issue-badge { padding: 3px 8px; border-radius: 6px; font-size: 11px; font-weight: 700; }
        .issue-scan { background: #e0f2fe; color: #0369a1; }
        .issue-absent { background: #f1f5f9; color: #475569; }
        .issue-leave { background: #fef3c7; color: #d97706; }
        .issue-late { background: #fae8ff; color: #a21caf; }
        
        /* Form elements */
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; font-size: 12px; font-weight: 600; color: var(--muted); margin-bottom: 6px; }
        .form-control, .form-select { width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); font-family: inherit; font-size: 14px; }
        .form-control:focus, .form-select:focus { border-color: var(--primary); outline: none; }
        
        /* Tabs */
        .tab-nav { display: flex; border-bottom: 2px solid var(--border); margin-bottom: 20px; gap: 20px; }
        .tab-btn { background: none; border: none; padding: 10px 5px; font-size: 14px; font-weight: 600; color: var(--muted); cursor: pointer; position: relative; }
        .tab-btn.active { color: var(--primary); }
        .tab-btn.active::after { content: ''; position: absolute; bottom: -2px; left: 0; right: 0; height: 2px; background: var(--primary); }
        
        /* Modal for Review */
        .modal-overlay { position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.4); z-index:1000; display:flex; align-items:center; justify-content:center; visibility:hidden; opacity:0; transition:all 0.3s; }
        .modal-overlay.active { visibility:visible; opacity:1; }
        .modal-box { background:#fff; width:95%; max-width:450px; border-radius:15px; padding:25px; box-shadow:0 10px 40px rgba(0,0,0,0.2); }
        .modal-box h3 { margin-top:0; font-size:18px; color:var(--primary); margin-bottom:20px; }
        
        /* Elapsed days badge */
        .elapsed-badge { padding: 2px 6px; border-radius: 4px; font-size: 10px; font-weight: 800; font-family: monospace; }
        .elapsed-danger { background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; }
        .elapsed-warning { background: #fef3c7; color: #f59e0b; border: 1px solid #fcd34d; }
        .elapsed-normal { background: #f1f5f9; color: #64748b; }
    </style>
</head>
<body>
    <%- include('components/sidebar') %>

    <div class="main">
        <%- include('components/topbar') %>

        <div class="page">
            <div class="page-header d-flex align-items-center justify-content-between" style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 24px;">
                <div>
                    <h4>แจ้งสาเหตุและแก้ต่างการลงเวลา</h4>
                    <p>ส่งใบแก้ต่างเมื่อเกิดปัญหา แสกนไม่ผ่าน / ขาด ลา มาสาย และตรวจสอบสถานะ</p>
                </div>
            </div>

            <% if (locals.user && (user.role === 'admin' || user.role === 'super')) { %>
                <!-- ================== ADMIN VIEW ================== -->
                <div class="list-card">
                    <div class="tab-nav">
                        <button class="tab-btn active" onclick="switchTab('pending')"><i class="bi bi-clock-history"></i> รายการรอตรวจสอบ</button>
                        <button class="tab-btn" onclick="switchTab('reviewed')"><i class="bi bi-check-circle"></i> ประวัติการพิจารณา</button>
                        <button class="tab-btn" onclick="switchTab('reminders')"><i class="bi bi-bell"></i> ค้างส่งเหตุผล (3-7 วัน) <span id="reminder-badge" style="background:#ef4444; color:#fff; font-size:10px; padding:2px 6px; border-radius:10px; display:none;">0</span></button>
                    </div>

                    <!-- TAB 1: PENDING -->
                    <div id="tab-pending" class="tab-content">
                        <div style="overflow-x:auto;">
                            <table class="att-tbl" style="width:100%;">
                                <thead>
                                    <tr>
                                        <th>บุคลากร</th>
                                        <th>วันที่เกิดปัญหา</th>
                                        <th>ประเภทปัญหา</th>
                                        <th>เหตุผล / ข้อชี้แจง</th>
                                        <th>เวลาที่ส่งเรื่อง</th>
                                        <th>จัดการ</th>
                                    </tr>
                                </thead>
                                <tbody id="pending-list">
                                    <!-- Dynamic -->
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- TAB 2: REVIEWED -->
                    <div id="tab-reviewed" class="tab-content" style="display:none;">
                        <div style="overflow-x:auto;">
                            <table class="att-tbl" style="width:100%;">
                                <thead>
                                    <tr>
                                        <th>บุคลากร</th>
                                        <th>วันที่เกิดปัญหา</th>
                                        <th>ประเภทปัญหา</th>
                                        <th>เหตุผล / ข้อชี้แจง</th>
                                        <th>สถานะ</th>
                                        <th>ความเห็นผู้ตรวจ</th>
                                        <th>วันที่ตรวจ</th>
                                    </tr>
                                </thead>
                                <tbody id="reviewed-list">
                                    <!-- Dynamic -->
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- TAB 3: REMINDERS (3-7 days) -->
                    <div id="tab-reminders" class="tab-content" style="display:none;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                            <div style="font-size:13px; color:var(--muted);">รายชื่อพนักงานที่มีสถิติ ขาด/สาย ในรอบ 7 วันที่ผ่านมา และยังไม่ได้ยื่นคำร้องแก้ต่างเข้ามาในระบบ</div>
                            <button class="btn btn-teal btn-sm" onclick="sendSelectedReminders()"><i class="bi bi-send"></i> ส่ง LINE แจ้งเตือนผู้ค้างส่ง</button>
                        </div>
                        <div style="overflow-x:auto;">
                            <table class="att-tbl" style="width:100%;">
                                <thead>
                                    <tr>
                                        <th style="width: 40px; text-align:center;"><input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)"></th>
                                        <th>ชื่อ-นามสกุล</th>
                                        <th>วันที่ค้าง</th>
                                        <th>ประเภทปัญหา</th>
                                        <th>จำนวนวันผ่านมา</th>
                                        <th>การเชื่อมต่อ LINE</th>
                                    </tr>
                                </thead>
                                <tbody id="reminders-list">
                                    <!-- Dynamic -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <!-- ================== EMPLOYEE VIEW ================== -->
                <div class="excuse-layout">
                    <!-- Left: Submission Form -->
                    <div class="form-card">
                        <h5 style="margin-top:0; font-size:16px; color:var(--primary); margin-bottom:18px;"><i class="bi bi-file-earmark-text-fill"></i> ยื่นคำร้องแก้ต่าง</h5>
                        <form id="excuseForm">
                            <div class="form-group">
                                <label>วันที่เกิดปัญหา</label>
                                <input type="date" id="date" class="form-control" required>
                            </div>
                            <div class="form-group">
                                <label>ประเภทปัญหา</label>
                                <select id="issue_type" class="form-select" required>
                                    <option value="scan-failed">แสกนใบหน้าไม่ผ่าน / ไม่ติด</option>
                                    <option value="absent">ไม่ได้สแกนบัตร / ขาดงาน</option>
                                    <option value="leave">ไม่ได้บันทึก ลา / ไปราชการ</option>
                                    <option value="late">ลืมเช็คอิน หรือเข้างานสาย</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>เหตุผล / ข้อชี้แจง</label>
                                <textarea id="reason" class="form-control" rows="4" placeholder="ระบุเหตุผล เช่น แสกนนิ้วไม่ผ่าน, เครื่องมีปัญหา, ไปราชการนอกสถานที่, รถติดหนักเนื่องจากฝนตก ฯลฯ" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-teal" style="width:100%; margin-top:10px;"><i class="bi bi-send-fill"></i> ส่งคำร้องแก้ต่าง</button>
                        </form>
                    </div>

                    <!-- Right: Submission History -->
                    <div class="list-card">
                        <h5 style="margin-top:0; font-size:16px; color:var(--primary); margin-bottom:18px;"><i class="bi bi-clock-history"></i> ประวัติการส่งคำร้องแก้ต่างของคุณ</h5>
                        <div style="overflow-x:auto;">
                            <table class="att-tbl" style="width:100%;">
                                <thead>
                                    <tr>
                                        <th>วันที่เกิดปัญหา</th>
                                        <th>ประเภทปัญหา</th>
                                        <th>เหตุผล / ข้อชี้แจง</th>
                                        <th>สถานะ</th>
                                        <th>ความเห็นผู้ตรวจ</th>
                                        <th>วันที่ยื่นคำร้อง</th>
                                    </tr>
                                </thead>
                                <tbody id="user-excuse-list">
                                    <tr><td colspan="6" style="text-align:center; padding:20px; color:var(--muted);">กำลังโหลดข้อมูล...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Review Modal (Admin only) -->
    <% if (locals.user && (user.role === 'admin' || user.role === 'super')) { %>
        <div class="modal-overlay" id="reviewModal">
            <div class="modal-box">
                <h3 id="modalTitle">พิจารณาใบแก้ต่างการลงเวลา</h3>
                <form id="reviewForm">
                    <input type="hidden" id="excuseId">
                    <div class="form-group">
                        <label>ชื่อพนักงาน: <strong id="lbl-fullname" style="color:var(--text)">—</strong></label>
                    </div>
                    <div class="form-group">
                        <label>วันที่เกิดปัญหา: <strong id="lbl-date" style="color:var(--text)">—</strong></label>
                    </div>
                    <div class="form-group">
                        <label>เหตุผลชี้แจง: <span id="lbl-reason" style="display:block; padding:10px; background:#f8fafc; border-radius:8px; margin-top:5px; font-size:13px; color:var(--text2);">—</span></label>
                    </div>
                    <div class="form-group">
                        <label>ผลการพิจารณา</label>
                        <select id="reviewStatus" class="form-select" required>
                            <option value="approved">✅ อนุมัติการแก้ต่าง</option>
                            <option value="rejected">❌ ไม่อนุมัติ / ยกเลิก</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>ความเห็นเพิ่มเติม (ส่งข้อความกลับเข้า LINE ผู้ส่งทันที)</label>
                        <textarea id="adminComment" class="form-control" rows="3" placeholder="ระบุเหตุผลในการอนุมัติหรือไม่อนุมัติ เช่น รับทราบปรับปรุงเวลาเช็คอินแล้ว, ข้อมูลไม่เพียงพอ ฯลฯ"></textarea>
                    </div>
                    <div class="actions" style="border:none; margin:0; padding:0; display:flex; justify-content:flex-end; gap:10px; margin-top:20px;">
                        <button type="button" class="btn btn-outline-dark" onclick="closeReviewModal()"><i class="bi bi-x-circle"></i> ยกเลิก</button>
                        <button type="submit" class="btn btn-teal"><i class="bi bi-floppy-fill"></i> บันทึกข้อมูล</button>
                    </div>
                </form>
            </div>
        </div>
    <% } %>

    <script>
        const userRole = '<%= locals.user ? user.role : "user" %>';
        const ISSUE_LABELS = {
            'scan-failed': '<span class="issue-badge issue-scan"><i class="bi bi-camera-fill"></i> แสกนไม่ผ่าน</span>',
            'absent': '<span class="issue-badge issue-absent"><i class="bi bi-x-square-fill"></i> ขาดงาน</span>',
            'leave': '<span class="issue-badge issue-leave"><i class="bi bi-calendar-minus-fill"></i> ลา</span>',
            'late': '<span class="issue-badge issue-late"><i class="bi bi-clock-fill"></i> มาสาย</span>'
        };

        const STATUS_LABELS = {
            'pending': '<span class="status-badge status-pending"><i class="bi bi-hourglass-split"></i> รอตรวจ</span>',
            'approved': '<span class="status-badge status-approved"><i class="bi bi-check-circle-fill"></i> อนุมัติ</span>',
            'rejected': '<span class="status-badge status-rejected"><i class="bi bi-x-circle-fill"></i> ไม่อนุมัติ</span>'
        };

        // Date helper
        function formatDate(dStr) {
            const d = new Date(dStr);
            return d.toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: 'numeric' });
        }

        // ============ FOR EMPLOYEES ============
        if (userRole !== 'admin' && userRole !== 'super') {
            const form = document.getElementById('excuseForm');
            if (form) {
                form.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const data = {
                        date: document.getElementById('date').value,
                        issue_type: document.getElementById('issue_type').value,
                        reason: document.getElementById('reason').value
                    };

                    try {
                        const res = await fetch('/api/excuses', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        });
                        const result = await res.json();
                        if (result.success) {
                            alert('✅ ส่งคำชี้แจงแก้ต่างเรียบร้อยแล้ว');
                            form.reset();
                            fetchUserExcuses();
                        } else {
                            alert('❌ บันทึกล้มเหลว: ' + result.error);
                        }
                    } catch (err) {
                        alert('❌ เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์');
                    }
                });
            }

            async function fetchUserExcuses() {
                try {
                    const res = await fetch('/api/excuses');
                    const data = await res.json();
                    const list = document.getElementById('user-excuse-list');
                    if (data.success && data.excuses.length > 0) {
                        list.innerHTML = data.excuses.map(ex => `
                            <tr>
                                <td><strong>${formatDate(ex.date)}</strong></td>
                                <td>${ISSUE_LABELS[ex.issue_type] || ex.issue_type}</td>
                                <td>${ex.reason}</td>
                                <td>${STATUS_LABELS[ex.status] || ex.status}</td>
                                <td><span style="font-size:12.5px; color:#475569;">${ex.admin_comment || '—'}</span></td>
                                <td><small style="color:var(--muted);">${new Date(ex.submitted_at).toLocaleString('th-TH')}</small></td>
                            </tr>
                        `).join('');
                    } else {
                        list.innerHTML = `<tr><td colspan="6" style="text-align:center; padding:20px; color:var(--muted);">คุณยังไม่มีประวัติการยื่นคำร้องแก้ต่าง</td></tr>`;
                    }
                } catch (err) {
                    console.error(err);
                }
            }

            // Initial load
            fetchUserExcuses();
        }

        // ============ FOR ADMINS ============
        let allExcuses = [];
        let allReminders = [];

        if (userRole === 'admin' || userRole === 'super') {
            function switchTab(tabId) {
                document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
                
                const activeBtn = Array.from(document.querySelectorAll('.tab-btn')).find(btn => btn.getAttribute('onclick').includes(`'${tabId}'`));
                if (activeBtn) activeBtn.classList.add('active');

                const content = document.getElementById('tab-' + tabId);
                if (content) content.style.display = 'block';

                if (tabId === 'pending' || tabId === 'reviewed') fetchAdminExcuses();
                if (tabId === 'reminders') fetchReminders();
            }

            async function fetchAdminExcuses() {
                try {
                    const res = await fetch('/api/excuses');
                    const data = await res.json();
                    if (data.success) {
                        allExcuses = data.excuses;
                        renderAdminExcuses();
                    }
                } catch (err) { console.error(err); }
            }

            function renderAdminExcuses() {
                const pendingList = document.getElementById('pending-list');
                const reviewedList = document.getElementById('reviewed-list');

                const pending = allExcuses.filter(ex => ex.status === 'pending');
                const reviewed = allExcuses.filter(ex => ex.status !== 'pending');

                if (pending.length > 0) {
                    pendingList.innerHTML = pending.map(ex => `
                        <tr>
                            <td><strong>${ex.fullname}</strong><br><small style="color:var(--muted)">@${ex.username}</small></td>
                            <td><strong>${formatDate(ex.date)}</strong></td>
                            <td>${ISSUE_LABELS[ex.issue_type] || ex.issue_type}</td>
                            <td><div style="max-width:300px; white-space: normal;">${ex.reason}</div></td>
                            <td><small style="color:var(--muted);">${new Date(ex.submitted_at).toLocaleString('th-TH')}</small></td>
                            <td>
                                <button class="btn btn-teal btn-sm" onclick="openReviewModal(${JSON.stringify(ex).replace(/"/g, '&quot;')})"><i class="bi bi-shield-check"></i> ตรวจสอบ</button>
                            </td>
                        </tr>
                    `).join('');
                } else {
                    pendingList.innerHTML = `<tr><td colspan="6" style="text-align:center; padding:20px; color:var(--muted);">ไม่มีรายการค้างตรวจสอบในระบบ</td></tr>`;
                }

                if (reviewed.length > 0) {
                    reviewedList.innerHTML = reviewed.map(ex => `
                        <tr>
                            <td><strong>${ex.fullname}</strong><br><small style="color:var(--muted)">@${ex.username}</small></td>
                            <td><strong>${formatDate(ex.date)}</strong></td>
                            <td>${ISSUE_LABELS[ex.issue_type] || ex.issue_type}</td>
                            <td><div style="max-width:300px; white-space: normal;">${ex.reason}</div></td>
                            <td>${STATUS_LABELS[ex.status] || ex.status}</td>
                            <td><span style="font-size:12.5px; color:#475569;">${ex.admin_comment || '—'}</span></td>
                            <td><small style="color:var(--muted);">${ex.reviewed_at ? new Date(ex.reviewed_at).toLocaleString('th-TH') : '—'}</small></td>
                        </tr>
                    `).join('');
                } else {
                    reviewedList.innerHTML = `<tr><td colspan="7" style="text-align:center; padding:20px; color:var(--muted);">ไม่มีประวัติการพิจารณาตรวจสอบ</td></tr>`;
                }
            }

            async function fetchReminders() {
                try {
                    const res = await fetch('/api/excuses/reminders');
                    const data = await res.json();
                    if (data.success) {
                        allReminders = data.reminders || [];
                        renderReminders();
                    }
                } catch (err) { console.error(err); }
            }

            function renderReminders() {
                const list = document.getElementById('reminders-list');
                const badge = document.getElementById('reminder-badge');
                
                // Show badge count
                if (allReminders.length > 0) {
                    badge.textContent = allReminders.length;
                    badge.style.display = 'inline-block';
                } else {
                    badge.style.display = 'none';
                }

                if (allReminders.length > 0) {
                    list.innerHTML = allReminders.map((r, index) => {
                        let elapsedClass = 'elapsed-normal';
                        if (r.elapsed_days === 3) elapsedClass = 'elapsed-warning';
                        if (r.elapsed_days >= 7) elapsedClass = 'elapsed-danger';

                        let lineStatus = '<span style="color:#ef4444;"><i class="bi bi-x-circle-fill"></i> ไม่มี LINE ID</span>';
                        if (r.has_line) {
                            lineStatus = '<span style="color:#10b981;"><i class="bi bi-check-circle-fill"></i> พร้อมเตือน LINE</span>';
                        }

                        const thaiIssue = r.issue_type === 'late' ? 'มาสาย' : 'ขาดงาน / ไม่แสกน';

                        return `
                            <tr>
                                <td style="text-align:center;">
                                    <input type="checkbox" class="remind-chk" data-index="${index}" ${r.has_line ? 'checked' : 'disabled'}>
                                </td>
                                <td><strong>${r.fullname}</strong><br><small style="color:var(--muted)">@${r.username}</small></td>
                                <td><strong>${formatDate(r.date)}</strong></td>
                                <td>${ISSUE_LABELS[r.issue_type] || r.issue_type}</td>
                                <td>
                                    <span class="elapsed-badge ${elapsedClass}">${r.elapsed_days} วันที่ผ่านมา</span>
                                </td>
                                <td>${lineStatus}</td>
                            </tr>
                        `;
                    }).join('');
                } else {
                    list.innerHTML = `<tr><td colspan="6" style="text-align:center; padding:20px; color:var(--muted);">ยินดีด้วย! ไม่มีรายการค้างส่งแจ้งเตือนในรอบ 7 วัน</td></tr>`;
                }
            }

            function toggleSelectAll(master) {
                document.querySelectorAll('.remind-chk').forEach(chk => {
                    if (!chk.disabled) {
                        chk.checked = master.checked;
                    }
                });
            }

            async function sendSelectedReminders() {
                const chks = document.querySelectorAll('.remind-chk:checked');
                if (chks.length === 0) {
                    alert('⚠️ กรุณาเลือกพนักงานที่ต้องการส่งข้อความแจ้งเตือนอย่างน้อย 1 คน');
                    return;
                }

                const selectedCandidates = Array.from(chks).map(chk => {
                    const idx = parseInt(chk.getAttribute('data-index'));
                    return allReminders[idx];
                });

                if (!confirm(`ยืนยันการส่ง LINE Push Notification แจ้งเตือนไปยังพนักงานที่เลือกจำนวน ${selectedCandidates.length} คน หรือไม่?`)) return;

                try {
                    const res = await fetch('/api/excuses/send-reminders', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ candidates: selectedCandidates })
                    });
                    const result = await res.json();
                    if (result.success) {
                        alert('✅ ' + result.message);
                        fetchReminders();
                    } else {
                        alert('❌ การส่งข้อความล้มเหลว: ' + result.error);
                    }
                } catch (err) {
                    alert('❌ เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์');
                }
            }

            // Review Modal
            function openReviewModal(ex) {
                document.getElementById('reviewModal').classList.add('active');
                document.getElementById('excuseId').value = ex.id;
                document.getElementById('lbl-fullname').innerText = ex.fullname;
                document.getElementById('lbl-date').innerText = formatDate(ex.date);
                document.getElementById('lbl-reason').innerText = ex.reason;
                document.getElementById('adminComment').value = '';
                document.getElementById('reviewStatus').value = 'approved';
            }

            function closeReviewModal() {
                document.getElementById('reviewModal').classList.remove('active');
            }

            document.getElementById('reviewForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                const data = {
                    id: document.getElementById('excuseId').value,
                    status: document.getElementById('reviewStatus').value,
                    admin_comment: document.getElementById('adminComment').value
                };

                try {
                    const res = await fetch('/api/excuses/review', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const result = await res.json();
                    if (result.success) {
                        alert('✅ พิจารณาคำร้องแก้ต่างสำเร็จ');
                        closeReviewModal();
                        fetchAdminExcuses();
                    } else {
                        alert('❌ บันทึกล้มเหลว: ' + result.error);
                    }
                } catch (err) {
                    alert('❌ เกิดข้อผิดพลาดในการบันทึก');
                }
            });

            // Initial load for admin
            fetchAdminExcuses();
            // Pre-fetch reminders to update badges
            fetchReminders();
        }
    </script>
</body>
</html>
