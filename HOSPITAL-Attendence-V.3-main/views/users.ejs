            }
        }

        async function resetUserPassword(userId, fullname) {
            if (!confirm(`คุณต้องการรีเซ็ตรหัสผ่านของ ${fullname} เป็นค่าเริ่มต้น '1234' หรือไม่?`)) return;
            try {
                const res = await fetch(`/api/users/${userId}/reset-password`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Accept-Charset': 'utf-8' }
                });
                const result = await res.json();
                if (result.success) {
                    alert('✅ รีเซ็ตรหัสผ่านสำเร็จ: รหัสผ่านใหม่คือ 1234');
                } else {
                    alert('❌ เกิดข้อผิดพลาด: ' + (result.error || 'ไม่สามารถรีเซ็ตได้'));
                }
            } catch (err) {
                alert('❌ เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์');
            }
        }

        // Close search results when clicking outside
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.form-group')) {
                document.getElementById('searchResults').style.display = 'none';
            }
        });

        // Initial Load
        fetchUsers();
        fetchPersonnel();
    </script>
